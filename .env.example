DB_URI=mongodb://localhost:27017/your-database
PORT=8100
JWT_SECRET=your_secret_key
SLACK_ERROR_WEBHOOK=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Payphone
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=

# WhatsApp Bot (BuilderBot Cloud) — outbound notifications
BBC_PROJECT_BASE_URL=
BBC_API_KEY=

# Cron / payment reminders
CRON_SECRET=change-me-long-random
# Set to "off" to disable the in-process reminder loop (Vercel Cron runs it in prod)
PAYMENT_REMINDERS_LOCAL_CRON=

# Public webhook base — used to register Payphone Notificación Externa
WEBHOOK_PUBLIC_BASE=https://your-ngrok-or-prod-domain
